local function bodyvelocitycheck(c, checkit)
	local children = GetChildren(c.HumanoidRootPart)
	for i = 1,#children do
		local v = children[i]
		if v.ClassName == "BodyVelocity"then
			v:Destroy()
		end
	end
end

