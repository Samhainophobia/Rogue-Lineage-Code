				if not _G.Debris then repeat task.wait() until _G.Debris end
				_G.Debris:AddItem(injury,1.5)
			end
			if EnemyPlayer then
				local danger = enemy:FindFirstChild("Danger")or Instance.new("NumberValue",EnemyPlayer)
				danger.Name = "Danger"
				if danger.Value+45<120 then
					danger.Value+=30
				else
					danger.Value = 120
				end
			end
		end
		if info.injury == "chestgash" and not enemy:FindFirstChild("MonsterInfo") then
			if not blocking then
				if not enemy:FindFirstChild("ImpaleCD") and not enemydata.Injuries.Value:find(info.injury)then
					create("ImpaleCD",20,enemy)
					create("NoRegen",10,enemy)
					if not enemydata.Injuries.Value:find("chestgash") and (not FindFirstChild(EnemyPlayer.Backpack, "SlashResistance")) or CheckRace(enemydata, 'Kasparan') then
						enemydata.Injuries.Value = enemydata.Injuries.Value..",chestgash"
					end
				end
			end
		elseif info.injury == "leg"then
			if not enemy:FindFirstChild("InjuryCooldown") and FindFirstChild(enemy, "Unprotect") then
				injurecd = true
				eroot.Bonebreak:Play()
				if not enemydata.Injuries.Value:find("brokenleg") then 
					enemydata.Injuries.Value = enemydata.Injuries.Value..",brokenleg"
					eroot.Injury:Play()
					local injury = game.ReplicatedStorage.Assets.Injure:Clone()
					injury.Parent = eroot
					injury:Emit(3)
					if not _G.Debris then repeat task.wait() until _G.Debris end
					_G.Debris:AddItem(injury,1.5)
				end	
			end
			if FindFirstChild(enemy, "Unprotect") then
				create("Knocked",1.5,enemy)
				eroot.Bonebreak:Play()
				if not enemydata.Injuries.Value:find("brokenleg") then 
					enemydata.Injuries.Value = enemydata.Injuries.Value..",brokenleg"
					eroot.Injury:Play()
					local injury = game.ReplicatedStorage.Assets.Injure:Clone()
					injury.Parent = eroot
					injury:Emit(3)
					if not _G.Debris then repeat task.wait() until _G.Debris end
					_G.Debris:AddItem(injury,1.5)
				end	
			else
				create("Unprotect", false, enemy)
			end
		elseif info.injury == "spine"then
			if not enemy:FindFirstChild("InjuryCooldown") then
				injurecd = true
				eroot.Bonebreak:Play()
			end
			create("Knocked",2,enemy)
		end
		if injurecd then
			local f = Instance.new("Accessory") f.Name = "InjuryCooldown" f.Parent = enemy if not _G.Debris then repeat task.wait() until _G.Debris end
			_G.Debris:AddItem(f,1)
		end
	end
	if info.shriekerhit then
		local MonsI = character:FindFirstChild("MonsterInfo")
		if MonsI and MonsI.Master.Value and game.Players:GetPlayerFromCharacter(MonsI.Master.Value) and game.Players:GetPlayerFromCharacter(MonsI.Master.Value).Backpack:FindFirstChild("ShriekerHeal") and not enemy:FindFirstChild("Blocking") then
			character.MonsterInfo.Master.Value.Humanoid.Health += 8
		end
	end
	if info.damage then
		if not info.isdeferred then
			if info.physical and FindFirstChild(character,"HaseldanDamageMultiplier")then
				info.damage *= 1.25
			end
			if info.physical and FindFirstChild(character,"SSJDamageMultiplier")then
				info.damage *= 1.5
			end
			if not info.nobuff then
				local cursecount = getCurseCount(enemy)
				if cursecount > 0 then
					if playerdata and playerdata.Class.Value ~= "Master Necromancer" then
						info.damage *= math.clamp(1 + (cursecount * 0.2), 1, 2) 
					else
						info.damage *= math.clamp(1 + (cursecount * 0.15), 1, 1.6) 
					end	
				end
				local grimcursecount = getGrimCurse(enemy)
				if grimcursecount > 0 then
					info.damage *= math.clamp(1 + (grimcursecount * 0.15), 1, 1.2)
					print(info.damage)
				end
			end
			if FindFirstChild(character,"LifeSteal") and info.damage then
				local toheal: number = info.damage / 4
				if humanoid.Health + toheal < humanoid.MaxHealth then
					humanoid.Health += toheal
				else
					humanoid.Health = humanoid.MaxHealth
				end
			end
			if enemy ~= character then
				if character.LegendaryArtifacts:FindFirstChild("ShapedGlass") then
					if info.damage >= 30 then
						info.damage *= 1.3
					elseif info.damage >= 20 and info.damage < 30 then
						info.damage *= 1.5
					elseif info.damage >= 10 and info.damage < 20 then
						info.damage *= 1.8
					else
						info.damage *= 2
					end
				end
				if enemydata and CheckRace(enemydata, 'Dracula') then
					info.damage *= 0.80
				end
				if enemy.Boosts:FindFirstChild("Defense") then
					for _,v in enemy.Boosts:GetChildren() do
						if v.Name == "Defense" and v:IsA("NumberValue") then --Damage cutoff, make sure defense is set to a decimal.
							info.damage *= v.Value
						end
					end
				end
				if character.Boosts:FindFirstChild("Damage") then
					for _,v in character.Boosts:GetChildren() do
						if v.Name == "Damage" and v:IsA("NumberValue") then --Damage multiplier, any number is acceptible (nerfs below 1)
							info.damage *= v.Value
						end
					end
				end
			end
		end
		
		--print(typeof(info.damage), typeof(ehumanoid.Heath), debug.traceback())
		
		if ehumanoid.Health - info.damage > 3 or (enemy:FindFirstChild("MonsterInfo") and (enemy.MonsterInfo.MonsterType.Value == "Howler" or enemy.MonsterInfo.MonsterType.Value == "Terra Serpent" or enemy.MonsterInfo.MonsterType.Value == "Zombie Scroom" or enemy.MonsterInfo.MonsterType.Value == "Howwgy" or enemy.MonsterInfo.MonsterType.Value == "Ice Dragon"  or enemy.MonsterInfo.MonsterType.Value == "Golem King" or enemy.MonsterInfo.MonsterType.Value == "Golem Turret")) then
			if info.didhitreturn then
				anyreturn = true
			end
			if character ~= enemy and Player and info.physical then
				if Player.Backpack:FindFirstChild("DrawEnergy") then
					local gain = info.EGain or 7.5
					character.Energy.Value = math.clamp(character.Energy.Value + (gain), 0, 100)
				end
			end

			if not Deferred  then
				
				if enemy:FindFirstChild("Rings") and enemy:FindFirstChild("Rings"):FindFirstChild("Ishiin's Ring") then
					ehumanoid.Health -= info.damage * 1.40
				else
					ehumanoid.Health -= info.damage
				end
				
			else
				for i= 1, 10 do
					local dmg = info.damage / 10
			
					game.ServerStorage.Requests.TagHumanoid:Fire(character,enemy,{damage = dmg,nododge = true,nobuff = true,nofocusparry = true, isdeferred = true})
					if enemy:FindFirstChild("NoRegen") or enemy:FindFirstChild("NoRegenCD") then

					else
						create("NoRegen", 7, enemy) -- gives them no regen at all for half of the duration of the hit.
						create("NoRegenCD",7, enemy)
					end
					task.wait(.25)
				end
			end

		else
			if enemy.LegendaryArtifacts:FindFirstChild("ShapedGlass") and not FindFirstChild(enemy,"FreezeRoot") then
				pcall(function()
					for _,v in pairs(enemy:GetDescendants()) do
						if v:IsA("BasePart") or v:IsA("Decal") then
							v.Transparency = 0
							if v:IsA("BasePart") then
								v.Anchored = true
							end
						elseif v:IsA("ParticleEmitter") or v:IsA("Texture") or v:IsA("Sound") then
							v:Destroy()
						end
					end
				end)
				game.ReplicatedStorage.Requests.ShapedDeath:FireAllClients(enemy.HumanoidRootPart)
				pcall(function()
					create("Danger",30,EnemyPlayer)
				end)
				enemy:BreakJoints()
				enemy.Humanoid.Health = 0
				_G.Death(enemy,character)
				return
			end
			
			if info.donotknock then
				ehumanoid.Health = 0.1
				return
			end

			if (not enemy:FindFirstChild("MonsterInfo") or (enemy:FindFirstChild("MonsterInfo") and enemy.MonsterInfo.MonsterType.Value == "Shrieker")) or (enemy:FindFirstChild("MonsterInfo") and (enemy.MonsterInfo.MonsterType.Value ~= "Howler" and enemy.MonsterInfo.MonsterType.Value ~= "Terra Serpent" and enemy.MonsterInfo.MonsterType.Value ~= "Zombie Scroom" and enemy.MonsterInfo.MonsterType.Value ~= "Howwgy" and enemy.MonsterInfo.MonsterType.Value ~= "Ice Dragon" and enemy.MonsterInfo.MonsterType.Value ~= "Golem King" and enemy.MonsterInfo.MonsterType.Value ~= "Golem Turret")) then
				if enemy:FindFirstChild("CantBeKnocked") then
					print("ahh u mad")
				else
					ehumanoid.Health = 3
					create("Knocked", 10, ehumanoid.Parent)
				end
			end
			if not enemydata or (enemydata and not CheckRace(enemydata, 'Cameo')) or enemydata or (enemydata and not CheckRace(enemydata, 'TrueCameo')) then
				if enemy:FindFirstChild("CantBeKnocked") then
					print("ahh u mad")
				else
					local v2 = Instance.new("Accessory")
					v2.Name = "Unconscious"
					v2.Parent = ehumanoid.Parent
					if not _G.Debris then repeat task.wait() until _G.Debris end
					_G.Debris:AddItem(v2,10)
				end
			elseif enemydata and CheckRace(enemydata, 'Cameo') or enemydata and CheckRace(enemydata, 'TrueCameo') then
					enemydata.Injuries.Value = ""
					if not enemy:FindFirstChild("NoLoss") then
						enemydata.Lives.Value-=1
						if enemydata.Lives.Value <= 0 then
							_G.Death(enemy, character)
						end
					end
					enemy.Humanoid.PlatformStand = false
					enemy.Humanoid.AutoRotate = true
					if not enemy:FindFirstChild("NoLoss") then
						create("NoLoss", 5, enemy)
					end
					for _,v in pairs(workspace.Live:getChildren())do
						if v ~= enemy and v:FindFirstChild("HumanoidRootPart")then
							if (enemy.HumanoidRootPart.Position-v.HumanoidRootPart.Position).Magnitude<11 then
								game.ServerStorage.Requests.TagHumanoid:Fire(v,v,{mana = true,manaknockupself = true})
							end
						end
					end
					wait()


					for _,v in pairs(enemy:GetChildren())do
						if v.Name == "Knocked"or v.Name == "Unconscious"or v.Name == "Action"or v.Name == "NoDam"or v.Name == "FreezeRoot"then
							v:Destroy()
						end
					end

					enemy.HumanoidRootPart.Cameo:Emit(75)
					enemy.HumanoidRootPart.CameoGetUp:Play()
					enemy.Humanoid.Health += enemy.Humanoid.MaxHealth
					enemy.HumanoidRootPart.LightningHit:Play()
				end
			end
		end
	if info.falldamage and not info.injury then
		return
	end
	if FindFirstChild(character.Artifacts,"Bloodring") and info.damage then
		local Healthback: number = info.damage / 1.6
		if humanoid.Health + Healthback < humanoid.MaxHealth then
			humanoid.Health += Healthback
		else
			humanoid.Health = humanoid.MaxHealth
		end
	end
	if enemy:FindFirstChild("LastHit")then
		enemy.LastHit.Value = tick()
	end
	if EnemyPlayer and character~=enemy or EnemyPlayer and info.falldamage then
		if not info.nocombattag then
			local danger = enemy:FindFirstChild("Danger")or Instance.new("NumberValue",EnemyPlayer)
			danger.Name = "Danger"
			if danger.Value + 30 < 120 then
				danger.Value += 30
			else
				danger.Value = 120
			end
		end
	end
	-- [[ ANTI-FARM & UNDERDOG XP SYSTEM ]]
	-- Make sure it's a real attack (not poison, burn, fall damage, or hitting yourself)
	if character and enemy and character ~= enemy and info.damage and info.damage > 0 and not info.poison and not info.burn and not info.falldamage and not info.isdeferred then
		-- Ensure both are actual players (not monsters)
		if playerdata and enemydata then 
			local baseXP = 5 -- The default XP given for a standard hit
			local xpMultiplier = 1

			-- [[ 1. ANTI-ALT FARM CHECK (Are they fighting back?) ]]
			local isFightingBack = false
			-- If they have a weapon out, or have Danger/Combat Tag, they are fighting back
			if enemy:FindFirstChildWhichIsA("Tool") or enemy:FindFirstChild("CombatTag") or enemy:FindFirstChild("Charge") or enemy:FindFirstChild("Danger") then
				isFightingBack = true
			end

			if isFightingBack then
				xpMultiplier = xpMultiplier + 1.0 
			else
				xpMultiplier = xpMultiplier * 0.1 -- Defenseless alt farming gives basically 0 XP
			end

			-- [[ 2. FULL ROGUE LINEAGE CLASS TIER DICTIONARY ]]
			local classTiers = {
				["Freshie"] = 0, ["None"] = 0, [""] = 0, 
				["Thief"] = 1, ["Warrior"] = 1, ["Spear"] = 1, ["Acolyte"] = 1, ["Scholar"] = 1,

				["Assassin"] = 2, ["Blacksmith"] = 2, ["Illusionist"] = 2, ["Necromancer"] = 2, 
				["Monk"] = 2, ["Akuma"] = 2, ["DragonKnight"] = 2, ["Dragon Knight"] = 2, ["Greatsword"] = 2, ["Spy"] = 2, 
				["SigilKnight"] = 2, ["ChurchKnight"] = 2, ["Samurai"] = 2, ["Botanist"] = 2, 
				["Spearfisher"] = 2, ["Spearman"] = 2,

				["Shinobi"] = 3, ["Oni"] = 3, ["Faceless"] = 3, ["MasterIllusionist"] = 3, ["Master Illusionist"] = 3, ["Ronin"] = 3,
				["Abysswalker"] = 3, ["DarkSigilKnight"] = 3, ["Whisper"] = 3, ["Florist"] = 3,
				["TridentFisher"] = 3, ["SigilKnightCommander"] = 3, ["DeepKnight"] = 3, 
				["StreetFighter"] = 3, ["Lancer"] = 3, ["Master Necromancer"] = 3, ["DragonSage"] = 3, 
				["BeastSlayer"] = 3, ["Candence"] = 3, ["DragonSlayer"] = 3, ["Dragon Slayer"] = 3, ["Lapidarist"] = 3
			}

			local aTier = classTiers[playerdata.Class.Value] or 0
			local tTier = classTiers[enemydata.Class.Value] or 0

			if tTier > aTier then
				xpMultiplier = xpMultiplier + (0.5 * (tTier - aTier)) -- Underdog Bonus
			elseif aTier > tTier then
				xpMultiplier = xpMultiplier * 0.5 -- Punching Down Penalty
			end

			-- [[ 3. AWARD THE FINAL XP TO THE CORRECT WEAPON ]]
			local finalXP = math.floor(baseXP * xpMultiplier)

			if finalXP > 0 then
				local wType = playerdata.Weapon.Value

				-- Automatically applies XP to whatever weapon class they currently have equipped
				if (wType == "Sword" or wType == "Katana" or wType == "Greatsword") and playerdata:FindFirstChild("SwordXP") then
					playerdata.SwordXP.Value = playerdata.SwordXP.Value + finalXP
				elseif wType == "Dagger" and playerdata:FindFirstChild("DaggerXP") then
					playerdata.DaggerXP.Value = playerdata.DaggerXP.Value + finalXP
				elseif wType == "Spear" and playerdata:FindFirstChild("SpearXP") then
					playerdata.SpearXP.Value = playerdata.SpearXP.Value + finalXP
				elseif (wType == "None" or wType == "Caestus" or info.fist) and playerdata:FindFirstChild("FistXP") then
					playerdata.FistXP.Value = playerdata.FistXP.Value + finalXP
				end
			end
		end
	end
	return anyreturn
end
game.ServerStorage.Requests.TagHumanoid.Event:Connect(taghumanoid)

