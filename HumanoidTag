local function ray(startpos, endpos)
	local myParams = RaycastParams.new()
	myParams.FilterType = Enum.RaycastFilterType.Blacklist
	myParams.FilterDescendantsInstances = {workspace.Live, workspace.Thrown, workspace.AreaMarkers, workspace.MonsterSpawns}
	myParams.IgnoreWater = true

	local ray = workspace:Raycast(startpos, endpos, myParams)

	if ray then
		local dotProduct = ray.Normal:Dot(Vector3.new(0, 1, 0))
		if dotProduct <= 0.3 then
			return ray.Instance, ray.Position, ray.Normal
		end
	end
end
