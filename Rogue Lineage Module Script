local function DoAccessories(Player)
	if not Player.Character then return end
	local Character = game:GetService('Players'):GetCharacterAppearanceAsync(Player.CharacterAppearanceId)
	local TargetCharacter = Player.Character
	Character.Parent = game.ServerStorage

	local Accessories = {}
	local Hairs = {}

	for _, Child in pairs(Character:GetChildren()) do
		if Child:IsA("Accessory")then
			local Attachment = Child:FindFirstChildWhichIsA("Attachment", true)

			if Attachment then
				if Attachment.Name == "HairAttachment"then
				table.insert(Hairs, Child:Clone())
			end
		end
	end
end
	game.Debris:AddItem(Character,1)
	return Hairs
end

function dialogues.Terrance.v1(p,v)
	local data = game.ServerStorage.PlayerData:FindFirstChild(p.Name)
	if not data or not p.Character then
		return
	end
	
	local Bald = {"Groot","Scroom","Metascroom"}	-- only no hair if they literally cant have hair
	
	if v.page == 1 and table.find(Bald,data.Race.Value) then
		return {
			speaker = "Terrance";
			msg = "What should I be cutting? You don't seem to have any hair.";
			endchoice = "Bye."
		}
	end
	
	if v.page == 1 and p.PlayerGui:FindFirstChild("BarberGui") then
		return {
			speaker = "Terrance";
			msg = "Are you going to just stand there or are you going to get a haircut?";
			endchoice = "Bye."
		}
	end
	if v.page == 1 then
		return {
			speaker = "Terrance";
			msg = "Yo, I'm providing free haircuts to anyone interested. Want one?";
			choices = {"Yes","Restore my natural hair"};
			endchoice = "Bye."
		}
	elseif v.choice == "Restore my natural hair" and not table.find(Bald,data.Race.Value) then
		data.CurrentHats.Value = ""
		
		local Hairs = DoAccessories(p,data)
		local Race = data.Race.Value
		local RaceInfo = game.ReplicatedStorage.Info.Races:FindFirstChild(data.Race.Value)
		local FindFirstChild,WaitForChild = game.FindFirstChild,game.WaitForChild
		local HairColor = RaceInfo.HairColor
		
		task.spawn(function()
			for _,v in pairs(Hairs)do
				if not p.Character:FindFirstChild("Bald") and not RaceInfo:FindFirstChild("Bald") and not FindFirstChild(RaceInfo.Parent,"Bald") and not FindFirstChild(p.Character,"Bald") and data.CurrentHats.Value == "" then
					
					for i,v in ipairs(p.Character:GetDescendants()) do
						if v:IsA('Accessory') and v:FindFirstChild('Handle') and v.Handle:FindFirstChild('HairAttachment') then
							v:Destroy()
						end
					end
					
					v.Parent = p.Character
					if FindFirstChild(v,"Handle")then
						local SM = v.Handle:FindFirstChildWhichIsA("SpecialMesh")
						if SM then
							if data.Race.Value == "Deva1" then
								local Color1 = Color3.fromRGB(data.ManaColor.Value.r,data.ManaColor.Value.g,data.ManaColor.Value.b)
								SM.TextureId = "rbxassetid://2599831937"
								SM.VertexColor = Vector3.new(Color1.r,Color1.g,Color1.b)
							else
								SM.TextureId = "rbxassetid://2599831937"
								SM.VertexColor = Vector3.new(HairColor.Value.r,HairColor.Value.g,HairColor.Value.b)
							end
						end
						if data.Race.Value == "Deva1" then
							v.Handle.Color = Color3.fromRGB(data.ManaColor.Value.r,data.ManaColor.Value.g,data.ManaColor.Value.b)
						else
							v.Handle.Color = HairColor.Value
						end


					end
				else
					v:Destroy()
				end
			end


		end)
		
		return {
			speaker = "Terrance";
			msg = "There you go";
			endchoice = "Bye."
		}
	elseif v.choice == "Yes" then
		game.ServerStorage.Assets.BarberGui:Clone().Parent = p.PlayerGui
	end
end

