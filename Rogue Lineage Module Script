	if not data or not p.Character then
		return
	end
	if v.page == 1 then
		return dialogues.Shero.p1
	elseif v.page == 2 then
		if v.choice == "Yes." then
			local eyecount = 0
			for i,v in pairs(p.Backpack:GetChildren()) do
				if v.Name == "Shrieker Eye" then
					eyecount += 1
				end
			end
			for i,v in pairs(p.Character:GetChildren()) do
				if v.Name == "Shrieker Eye" then
					eyecount += 1
				end
			end
			if eyecount >= 50 then
				for i,v in pairs(p.Backpack:GetChildren()) do
					if v.Name == "Shrieker Eye" then
						require(game.ServerScriptService.Modules.Commands).RemoveFromInventory(p,v)
						v:Destroy()
					end
				end
				for i,v in pairs(p.Character:GetChildren()) do
					if v.Name == "Shrieker Eye" then
						require(game.ServerScriptService.Modules.Commands).RemoveFromInventory(p,v)
						v:Destroy()
					end
				end
				game.ServerStorage.Storage["Scroll of Shrieker Summoning"]:Clone().Parent = p.Backpack
				return dialogues.Shero.p2
			else
				return dialogues.Shero.p3
			end
		end
	end
end
dialogues.Vine.v1 = function(p,v)
	local data = game.ServerStorage.PlayerData:FindFirstChild(p.Name)
	if not data or not p.Character then
		return
	end
	if data.SubClass.Value ~= "" and data.SubClass.Value ~= "PoisonMaster" then
		return {speaker = "Vine",
			msg = "Scram.",
			endchoice = "Bye."
		}
	end

	if v.page == 1 then
		return {speaker = "Vine",
			msg = "So you want to learn the art of poison? Nothing's free. (150 silver)",
			choices = {"I'll pay."},
			endchoice = "Bye."
		}
	elseif v.page == 2 then
		if commands.ChangeSilver(p, data, -150, true) then
			data.SubClass.Value = "PoisonMaster"
			for i = 1,#classdata.PoisonMaster.skills do
				if not data.Skills.Value:find(classdata.PoisonMaster.skills[i]) then
					data.Skills.Value ..= ","..classdata.PoisonMaster.skills[i]
					commands.Learn(p)
					commands.ChangeSilver(p, data, -150)
					if classdata.PoisonMaster.skills[i] == "PoisonMastery" then
						return {speaker = "Vine",
							msg = "Good. Everything in this world is poisonous, you just need to find the combinations.",
							endchoice = "Bye."
						}
					elseif classdata.PoisonMaster.skills[i] == "PoisonCrafting" then
						return {speaker = "Vine",
							msg = "Good. Poison can be used in various ways... Including meals.",
							endchoice = "Bye."
						}
					else
						return {speaker = "Vine",
							msg = "Good.",
							endchoice = "Bye."
						}
					end
				end
			end
			return {speaker = "Vine",
				msg = "It seems like you have learned all I have to teach you.",
				endchoice = "Bye."
			}

		else
			return {speaker = "Vine",
				msg = "Scram.",
				endchoice = "Bye."
			}
		end
	end
end
