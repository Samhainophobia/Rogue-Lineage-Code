					if gotconstruct then
						if data.Race.Value == "Ashiin" then
							data.Race.Value = "Construct"
							data.Skills.Value ..= ",TrainedCombat"
						else
							data.Race.Value = "Construct"
						end
						if data.Lives.Value>3 then
							data.Lives.Value = 3
						end
						if Danger and Danger.Parent then
							Danger:Destroy()
						end
						local newlastpos = p.Character.HumanoidRootPart.Position + p.Character.HumanoidRootPart.CFrame.lookVector * 3
						newlastpos = newlastpos.X .. ",".. newlastpos.Y .. "," ..newlastpos.Z
						data.LastPosition.Value = newlastpos
						game.ServerStorage.Requests.Respawn:Fire(p)	
					else
						_G.Death(p)
					end
					return
				end)()
				return dialogues.exit
			else
				return dialogues["Lab Assistant"].no
			end
		end
	end
