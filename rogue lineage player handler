function CheckJarOfSouls(Enemy, PlayerData, Character)
	if not Enemy:FindFirstChild('JarDB') and PlayerData.Resonance.Value == 'Jar Of Souls' then
		local DB = Instance.new('Folder')
		DB.Name = 'JarDB'
		DB.Parent = Enemy
		local maxSoulGainPercentage = 20 -- // Killing a person with like 185 maxhp would reward like 37 souls 
		local soulGain = math.clamp(Enemy.Humanoid.MaxHealth / 100 * maxSoulGainPercentage, 0, 100)
		PlayerData.Souls.Value = math.clamp(PlayerData.Souls.Value + soulGain, 0, 100)
		game.ReplicatedStorage.Requests.ClientEffect:FireAllClients("SoulExecute", {Enemy,Character})
	end
end

local function edictRewards()
	if PlayerData:WaitForChild'EdictType'.Value ~= "" then
		local EdictData = EdictData[PlayerData.EdictType.Value]
		if not EdictData then
			return
		end
		local Marking = true
		if FakeHead:FindFirstChild("EdictMark") then
			Marking = false
		end
		if Marking then
			if EdictData.Face and PlayerData.Race.Value ~= 'Dzin' or PlayerData.Race.Value ~= 'TraumatizedDzin' then
				local face = EdictData.Face:Clone()
				face.Name = "EdictMark"
				face.Parent = FakeHead
			end
		end
		if EdictData.Skills then
			for _,v in ipairs(EdictData.Skills) do
				if not Player.Backpack:FindFirstChild(v.Skill.Name) and not Character:FindFirstChild(v.Skill.Name) then
					if PlayerData.EdictProgression.Value >= v.ProgressRequirement and PlayerData.DaysSurvived.Value >= v.DayRequirement then
						v.Skill:Clone().Parent = Player.Backpack
					end
				end
			end
		end
	end
end

