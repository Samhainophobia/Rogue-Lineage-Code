function SetModelCollisionGroup(Model, Group)
	for _, v in pairs(Model:GetChildren()) do
		if v:IsA("BasePart") then
			game:GetService('PhysicsService'):SetPartCollisionGroup(v, Group)
		end
	end
end

function Raycast(Ray, IgnoreList)
	IgnoreList = IgnoreList or {}
	while true do
		local Part, Position, Normal = workspace:FindPartOnRayWithIgnoreList(Ray, IgnoreList)
		if not Part then
			break
		end
		if Part:IsA("BasePart") then
			if Part.Transparency ~= 1 and Part.CanCollide then
				return Part, Position, Normal
			else
				table.insert(IgnoreList, Part)
			end
		end
	end
end

