													if VPlayerData.Artifact.Value ~= "None"and APlayerData.Artifact.Value == "None"then
														APlayerData.Artifact.Value = VPlayerData.Artifact.Value
													end
												end
											end
										end
									end)
									if err then
										warn("GRIPPING: "..err)
									end
								end
							end
						end
					end
					if NPC:IsDescendantOf(workspace)and ex1.Value and ex1.Parent then
