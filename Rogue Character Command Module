local create = function(name,deletetime,parent)
	local i = Instance.new("Accessory")
	i.Name = name
	i.Parent = parent
	if deletetime then
		if not _G.Debris then repeat task.wait() until _G.Debris end
		_G.Debris:AddItem(i,deletetime)
	end
	return i
end
