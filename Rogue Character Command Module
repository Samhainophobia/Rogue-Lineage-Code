local currDebs = script["#ToolDebounces"]
local function debUp(p,t)
	if p and t then
		if p:FindFirstChild("DingDing") then
			return
		end
		local f = Instance.new("Folder")
		f.Name = p.Name.."|"..t.Name
		f.Parent = currDebs
		if not _G.Debris then repeat task.wait() until _G.Debris end
		_G.Debris:AddItem(f, 20)
		task.delay(15,function()
			f:Destroy()
		end)
	end
end

commands["UpdateSkills"] = function(player)
	local data = PlayerDatas:WaitForChild(player.Name)
	if data.Race.Value == 'Navaran'or data.Race.Value == "LesserNavaran" then
		local tool = game.ServerStorage.Classes:FindFirstChild(data.Emulated.Value)
		if tool then
			if currDebs:FindFirstChild(player.Name.."|"..tool.Name) and not player:FindFirstChild("ForgiveThem") then
			else
				local found = player.Backpack:FindFirstChild(tool.Name)or player.Character:FindFirstChild(tool.Name)
				if not found then
					for _,v in pairs(player.Backpack:getChildren())do
						if v:FindFirstChild("Emulated")then
							v:Destroy()
						end
					end
					for _,v in pairs(player.Character:getChildren())do
						if v:FindFirstChild("Emulated")then
							v:Destroy()
						end
					end
					local sc = tool:Clone()
					debUp(player, sc)
					create("Emulated",false,sc)
					task.wait()
					sc.Parent = player.Backpack
				end
			end
		end
	end

	local skills = string.split(data.Skills.Value,",")
	if table.find(skills, "The Soul") then
		if not game.CollectionService:HasTag(player.Character, "The Soul") then
			game.CollectionService:AddTag(player.Character, "The Soul")
		end
	else
		if  game.CollectionService:HasTag(player.Character, "The Soul") then
			game.CollectionService:RemoveTag(player.Character, "The Soul")
		end
	end
	if #skills > 0 then
		for Indx, Skill in pairs(skills)do
			local sc = game.ServerStorage.Classes:FindFirstChild(Skill) or (data.Race.Value == 'Navaran'and game.ServerStorage.RacialAbilities:FindFirstChild(Skill))
			if sc then
				if currDebs:FindFirstChild(player.Name.."|"..sc.Name) and not player:FindFirstChild("ForgiveThem") then
				else
					if sc:FindFirstChild("RequiresWeapon")then
						if sc.RequiresWeapon.Value ~= data.Weapon.Value and not ((sc.Name == "Dark Flame Burst" and data.Weapon.Value == "Sword") or (sc.Name == "Dark Eruption" and data.Weapon.Value == "Sword")) and sc.RequiresWeapon.Value ~= data.PrimaryWeapon.Value then
							if not allskillsspec[player.Name]then
								continue
							end
						end
					end
					local found = player.Backpack:FindFirstChild(Skill)or player.Character:FindFirstChild(Skill)
					if not found then
						debUp(player, sc)
						sc:Clone().Parent = player.Backpack
					end
				end
			end
		end
		for _,v in pairs(player.Backpack:GetChildren())do
			if v:FindFirstChild("RequiresWeapon")then
				if v.RequiresWeapon.Value ~= data.Weapon.Value and v.RequiresWeapon.Value ~= data.PrimaryWeapon.Value then
					if not allskillsspec[player.Name]then
						v:Destroy()
					end
				end
			end
			if v:FindFirstChild("DestroySkill")then
				v:Destroy()
			end
		end
	end
end

