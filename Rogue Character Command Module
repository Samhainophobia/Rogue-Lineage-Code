			data.DyeColor.Value = ""
		end
		if game:GetService("MarketplaceService"):UserOwnsGamePassAsync(player.UserId,076532231) or (data:FindFirstChild("Rank") and data.Rank.Value > 0 and data.Rank.Value <= 5) or (_G.GetAdminLevel(player.UserId) > 0) or (player.Name == "astrookrispp") then
			if data.VanityOff.Value == false then return end
			local shirt = character:WaitForChild'Shirt'
			local pants = character:WaitForChild'Pants'
			local async
			local function asyncer()
				local pc,err = pcall(function()
					async = getAppearance(player)
				end)
				if not pc then
					print("Async failed, retrying...")
					task.wait(0.5)
					asyncer()
				else
					return
				end
			end
			asyncer()
			if async:FindFirstChild("Shirt") and async:FindFirstChild("Pants") then
				local newshirt = async:WaitForChild("Shirt").ShirtTemplate
				local newpants = async:WaitForChild("Pants").PantsTemplate
