local function CheckRace(PlayerData, Race)
	local IsRace = false
	if PlayerData.Race.Value == Race then
		IsRace = true
	elseif PlayerData.Race.Value == 'Navaran' then
		if PlayerData.CopiedRaces.Value:find(Race) then
			IsRace = true
		end
	end

	return IsRace
end


local function CheckRace2(Value: StringValue, Race: string)
	local IsRace = false
	local PlayerData = Value:FindFirstAncestorOfClass('Folder')

	if Value.Value == Race then
		IsRace = true
	elseif Value.Value == 'Navaran' then
		if PlayerData.CopiedRaces.Value:find(Race) then
			IsRace = true
		end
	end

	return IsRace
end


local function getAppearance(Player)
	local Char
	local pc,err = pcall(function()
		Char = game.Players:GetCharacterAppearanceAsync(Player.CharacterAppearanceId)
	end)
	if not Char then
		print("getAppearance Failed, retrying in 0.5",err)
		task.wait(0.5)
		return getAppearance(Player)
	else
		return Char
	end
end

local function DoAccessories(Player,Data)
	local Character = getAppearance(Player)
	Character.Parent = game.ServerStorage
	pcall(function() --this is not a backdoor
		local additional = Data:FindFirstChild("AdditionalAccessories")
		if additional and additional.Value ~= "[]" then
			local js = game.HttpService:JSONDecode(additional.Value)
			if table.find(js,"Overwrite") then
				for _,v in ipairs(Character:GetChildren())do
					if v:IsA("Accessory")then
						print(v)
						v:Destroy()
					end
				end
			end
			for _,v in js do
				local accessory = game:GetService("InsertService"):LoadAsset(v)
				if not accessory then continue end
				for _,v in accessory:GetChildren() do
					if not v or (v and not v:IsA("Accessory")) then continue end
					Instance.new("Folder",v).Name = "Bypass"
					v.Parent = Character
				end

				accessory:Destroy()
			end
		end
	end)
	local Hairs,Accessories = {},{}
	for _,v in ipairs(Character:GetChildren())do
		if v:IsA("Accessory") then
			local Attachment = v:FindFirstChildWhichIsA("Attachment",true)
			if table.find(BlacklistedObjects,v.ClassName) then
				v:Destroy()
			end

			if v.Name:find("Snorkel") then
				table.insert(Accessories,v:Clone()) continue
			end

			if v.Name:find("FatherTime") then
				table.insert(Hairs,v:Clone()) continue
			end

			if v.Name == "EarsAccessory" then
				table.insert(Hairs,v:Clone()) continue
			end

			if Attachment then
				if Attachment.Name == "HairAttachment" then
					table.insert(Hairs,v:Clone()) continue
				elseif Attachment.Name == "FaceFrontAttachment"then
					table.insert(Accessories,v:Clone()) continue
				elseif Attachment.Name == "FaceCenterAttachment"then
					table.insert(Accessories,v:Clone()) continue
				elseif Data.LastName.Value == 'Cycloptic' or Player.Name == 'Cycloptic_Cam' or Player.Name == 'Nebuloussu' then
					table.insert(Accessories,v:Clone()) continue
				end

			end

			if v:FindFirstChild("Bypass") then
				table.insert(Accessories,v:Clone())
			end
		end
	end
	if not _G.Debris then repeat task.wait() until _G.Debris end
	_G.Debris:AddItem(Character,1)
	return Hairs,Accessories
end


commands["Learn"] = function(p)
	local c
	if p:IsA("Model") then 
		c = p
		p = game.Players:GetPlayerFromCharacter(c)
	else	
		c = p.Character or p.CharacterAdded:Wait()
	end
	c.HumanoidRootPart:WaitForChild("Learn"):Play()
	local l1 = game.ServerStorage.Assets.Learn.Attachment:Clone()
	l1.ParticleEmitter.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0,p.Backpack:WaitForChild("ManaColor").Value),
		ColorSequenceKeypoint.new(1,p.Backpack:WaitForChild("ManaColor").Value),
	})
	l1.Parent = c:WaitForChild("Head")
	l1.ParticleEmitter:Emit(15)
	if not _G.Debris then repeat task.wait() until _G.Debris end
	_G.Debris:AddItem(l1,1.5)
end

local function weldBetween(a, b, offset)
	local weld = Instance.new("ManualWeld", a)
	weld.C0 = offset
	weld.Part0 = a
	weld.Part1 = b
	return weld
end


