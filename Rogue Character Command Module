commands["StopBurn"] = function(character)
	if character and character.Parent then
		for i,v in pairs(character:GetChildren())do
			if v.Name == "Burning" and not v:FindFirstChild("NoExtinguish") then
				v:Destroy()
				create("BurnCooldown",2,character)
				if character and character:FindFirstChild("HumanoidRootPart")  then
					character.HumanoidRootPart.Extinguish:Play()
					character.HumanoidRootPart.LoopFire:Stop()
				end
			end
		end
		for i,v in pairs(character.HumanoidRootPart:GetChildren())do
			if v.Name == "Burning" or v.Name == "ColoredBurning" and not v:FindFirstChild("NoExtinguish") then
				v.Enabled = false
				if not _G.Debris then repeat task.wait() until _G.Debris end
				_G.Debris:AddItem(v,1)
				if character and character:FindFirstChild("HumanoidRootPart") then
					character.HumanoidRootPart.LoopFire:Stop()
				end
			end
		end
	end
end
commands["StartBurn"] = function(enemy,eroot,color,burninfo,firestarter)
	if enemy:FindFirstChild("Burning")then
		return
	end
	if enemy:FindFirstChild("BurnCooldown")then
		return
	end
	if enemy:FindFirstChild("NoBURN")then
		return
	end
	if not enemy:FindFirstChild("MonsterInfo")and game.ServerStorage.PlayerData:FindFirstChild(enemy.Name) and (game.ServerStorage.PlayerData[enemy.Name].Race.Value == "Azael") and not (burninfo and burninfo.manastop) then
		return
	end
	task.spawn(function()
		local burn = create("Burning",false,enemy)
		local noreg = create("NoRegen",false,enemy)
		local executes = true
		if burninfo and burninfo.manastop then
			create("ManaStop",5,enemy)
			local p = color and game.ServerStorage.Assets.ColoredBurning:Clone() or game.ServerStorage.Assets.Burning:Clone()
			if color then
				p.Color = ColorSequence.new({ColorSequenceKeypoint.new(0,color),ColorSequenceKeypoint.new(1,color),})
			end
			p.Parent = eroot
			p.Enabled = true
			Instance.new("Folder", p).Name = "NoExtinguish"
			task.spawn(function()
				for i = 1,10 do
					game.ServerStorage.Requests.TagHumanoid:Fire(firestarter or enemy,enemy,{damage = 0.1,nocombattag = true,downbypass = true,nododge = true})
					task.wait(0.5)
				end
				enemy.HumanoidRootPart.Extinguish:Play()
				p:Destroy()
			end)
		end
		if burninfo and burninfo.wraithfire then
			executes = false
			if not _G.Debris then repeat task.wait() until _G.Debris end
			_G.Debris:AddItem(burn,5)
		end
		eroot.LoopFire:Play()
		local p = color and game.ServerStorage.Assets.ColoredBurning:Clone() or game.ServerStorage.Assets.Burning:Clone()
		if color then
			p.Color = ColorSequence.new({ColorSequenceKeypoint.new(0,color),ColorSequenceKeypoint.new(1,color),})
		end
		p.Parent = eroot
		p.Enabled = true
		enemy.HumanoidRootPart.LoopFire:Play()
		task.wait(0.25) -- // 0.25
		while true do
			if not burn or not burn.Parent then
				break
			end
			if enemy.Humanoid.Health <= 0 then
				break
			end
			if enemy.Humanoid:GetState() == Enum.HumanoidStateType.Swimming then
				break
			end
			if enemy:FindFirstChild('Swimming') then
				break
			end
			local dmg = 2.4375
			local timetoburn = 2
			if burninfo and burninfo.TanjiroBurn then
				dmg = 1.2
			end
			if game.CollectionService:HasTag(enemy,"Vampirism") then
				dmg*=1.6
			end
			if burninfo and burninfo.wraithfire then
				dmg = 0.5
			end
			temphandler.CHANGE_TEMPERATURE(enemy,1,0.0125)
			if enemy:FindFirstChild("AntiBurn") then
				task.wait(0.1)
				commands.StopBurn(enemy)
			end
			if game.ServerStorage.PlayerData:FindFirstChild(enemy.Name) and burninfo and burninfo.WhiteFire then
				if enemy.Boosts:FindFirstChild("Vampirism") then
					dmg *= 1.2
				end
				if game.ServerStorage.PlayerData:FindFirstChild(enemy.Name).Alignment.Value < 0 then
					dmg *= 1.2
				end
				game.ServerStorage.Requests.TagHumanoid:Fire(firestarter or enemy,enemy,{damage = dmg,downbypass = true,nododge = true})
			else
				game.ServerStorage.Requests.TagHumanoid:Fire(firestarter or enemy,enemy,{damage = dmg,nocombattag = true,downbypass = true,nododge = true})
			end
			task.wait(0.5)
			if executes then
				local Hum = enemy:FindFirstChild'Humanoid'
				if Hum and Hum.Health <= 3 then
					if game.CollectionService:HasTag(enemy,"Vampirism") then
						timetoburn = 0.5
					end
					if not game.CollectionService:HasTag(enemy, "Vampirism") then
						task.wait(timetoburn)
					else
						task.wait(timetoburn/2)
					end
					if not burn or not burn.Parent then
						break
					end
					if not enemy:FindFirstChild("Knocked") then
						break
					end
					if not enemy:FindFirstChild("Unconscious") then
						break
					end
					if enemy.Humanoid:GetState() == Enum.HumanoidStateType.Swimming then
						break
					end
					if enemy.Humanoid.Health <= 0 then
						break
					end
					game.ServerStorage.Requests.TagHumanoid:Fire(firestarter or enemy,enemy,{injury = "heat",downbypass = true,nododge = true})

					task.wait(timetoburn*2)



					if not burn or not burn.Parent then
						break
					end
					if not enemy:FindFirstChild("Knocked") then
						break
					end
					if not enemy:FindFirstChild("Unconscious") then
						break
					end
					if enemy:FindFirstChild("Grabbed") then
						break
					end
					if enemy:FindFirstChild("beinggrabbed") then
						return
					end
					if Hum:GetState() == Enum.HumanoidStateType.Swimming then
						break
					end
					if Hum.Health <= 0 then
						break
					end
					if enemy.Humanoid.Health > 0 then
						_G.Death(enemy,firestarter,true)
						for i,v in pairs(enemy:GetChildren()) do
							if v:IsA("Clothing") then
								v:Destroy()
							end
							if v:IsA("BasePart") then
								v.Material = Enum.Material.Slate
								game:GetService("TweenService"):Create(v,TweenInfo.new(3),{Size = Vector3.new(0,0,0)}):Play()
							end
						end
					end
				end
			end
		end
		commands.StopBurn(enemy)
		noreg:Destroy()
	end)
end

return commands
